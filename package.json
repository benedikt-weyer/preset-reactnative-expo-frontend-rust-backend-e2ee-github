{
  "name": "preset-reactnative-frontend-rust-backend-e2ee-github",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "pnpm db:restart && turbo dev --ui=tui",
    "devstop": "pnpm db:down",
    "dev:backend": "turbo -F backend dev --ui=tui",
    "dev:docs": "turbo -F docs dev",
    "dev:web": "turbo -F web dev --ui=tui",
    "dev:mobile": "turbo -F mobile dev --ui=tui",

    "setupenv": "node ./scripts/setupenv.mjs",

    "build": "turbo build",
    "build:docs": "turbo -F docs build",
    "build:web": "turbo -F web build",
    "build:web:docker": "docker build -t preset-web -f apps/web/Dockerfile .",
    "build:mobile": "turbo -F mobile build",
    "build:backend": "turbo -F backend build",
    "build:backend:docker": "docker build -t preset-backend -f apps/backend/Dockerfile apps/backend",

    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:restart": "pnpm db:down && pnpm db:up",

    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "check": "turbo typecheck lint check test",

    "test": "turbo test",
    "test:web": "turbo -F web test"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}